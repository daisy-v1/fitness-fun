import SwiftUI
import AVKit

struct HomeView: View {
    var body: some View {
        NavigationView {
            VStack {
                NavigationLink(destination: VideoView()) {
                    Text("Workout Videos")
                        .font(.headline)
                        .padding()
                        .frame(width: 220, height: 50)
                        .background(Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(10)
                }
            }
        }
    }
}

struct VideoView: View {
    var body: some View {
        VStack {
            Text("Workout Videos")
                .font(.largeTitle)
                .bold()
            
            VideoPlayer(player: AVPlayer(
                url: URL(string: ".mp4")!
            ))
            .frame(height: 250)
            .cornerRadius(12)
            
            Spacer()
        }
        .padding()
    }
}
